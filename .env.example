# ─── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
# Pooler Transaction mode — para runtime (puerto 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexión directa — solo para prisma migrate (puerto 5432)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=contraseña-de-aplicacion-gmail
EMAIL_FROM_NAME=CRM Inmobiliaria
EMAIL_FROM_ADDRESS=tu-correo@gmail.com

# ─── Google Drive (opcional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ─── Firma electrónica Signaturit (opcional) ──────────────────────────────────
SIGNATURIT_API_KEY=
SIGNATURIT_BASE_URL=https://api.signaturit.com/v1

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Reseñas postventa (opcional) ────────────────────────────────────────────
GOOGLE_BUSINESS_URL=https://g.page/r/TU_ID_DE_NEGOCIO/review
TRUSTPILOT_URL=https://www.trustpilot.com/evaluate/tuagencia.com
